# ─────────────────────────────────────────────────────────────────────────────
# Configuración del Sistema de Asignación de Ayudantes
# Copia este archivo como .env y completa los valores reales.
#   cp .env.example .env
# El archivo .env NO debe subirse al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Entorno de ejecución:
#   LOCAL → lee las variables desde este archivo .env (desarrollo)
#   PROD  → lee las variables desde el entorno del contenedor (docker-compose)
ENVIRONMENT=LOCAL

# Rol de la instancia / build:
#   admin    → perfil facultad: ve todos los datos
#   profesor → oculta el RUT del alumno y solo muestra la nota del ramo filtrado
APP_ROLE=admin

# ── Credenciales de Google Cloud (Service Account) ───────────────────────────
# Opción A (recomendada): el JSON completo de la Service Account como string.
# Pégalo en una sola línea, con las comillas exteriores.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com", "...": "..."}'

# Opción B (solo local): ruta a un archivo JSON en disco. Si defines la Opción A,
# esta se ignora.
# GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service-account.json

# ── URLs de las planillas de Google Sheets ───────────────────────────────────
# Cada planilla debe estar COMPARTIDA con el correo de la Service Account
# (como Lector o Editor). Pueden ser Google Sheets nativos o archivos .xlsx
# subidos a Drive; en este último caso debe estar habilitada la "Google Drive API"
# en el proyecto de Google Cloud.

#URL hoja Cumplimiento de Malla Pregrado
SPREADSHEET_URL_MALLA=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit

#URL hoja Reporte Alumnos con Promedio
SPREADSHEET_URL_PROMEDIOS=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit

#URL hoja Listado de NRC por Periodo
SPREADSHEET_URL_NRC=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit

#URL hoja Ramos Inscritos por Periodo
SPREADSHEET_URL_INSCRITOS=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit

#URL hoja Postulaciones a ayudantias
SPREADSHEET_URL_POSTULACIONES=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit

#URL hoja Plan de Estudios / Malla Nueva (catalogo de cursos + requisitos)
SPREADSHEET_URL_PLAN_ESTUDIOS=https://docs.google.com/spreadsheets/d/XXXXXXXXXXXX/edit

# ── Parámetros del pipeline (opcionales, con valores por defecto) ─────────────
# Nota mínima en el ramo para ser candidato a ayudante (escala 1–7).
NOTA_MINIMA_AYUDANTE=5.0
# Máximo de ayudantías simultáneas por alumno.
MAX_AYUDANTIAS_ALUMNO=3
